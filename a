<!DOCTYPE html>
<html lang="hi">
<head>
    
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HPL Auction Control Room - Fixed Pars</title>
    <style>
        :root { --primary: #1e3799; --success: #27ae60; --danger: #c0392b; --warning: #f1c40f; --info: #3498db; }
        body { font-family: 'Poppins', sans-serif; background: #f4f7f6; margin: 0; padding: 20px; color: #333; }
        .auction-card { background: white; max-width: 500px; margin: auto; padding: 30px; border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); border-top: 8px solid var(--primary); text-align: center; }
        #playerPhoto { width: 180px; height: 180px; border-radius: 50%; border: 5px solid var(--primary); object-fit: cover; margin-bottom: 10px; background: #eee; }
        .controls { display: flex; flex-direction: column; gap: 15px; margin-top: 25px; }
        input, select { padding: 14px; border-radius: 10px; border: 1px solid #ddd; font-size: 16px; width: 100%; box-sizing: border-box; }
        .btn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        button { padding: 14px; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; font-size: 16px; transition: 0.3s; }
        button:disabled { opacity: 0.5; cursor: not-allowed; }
        .sold { background: var(--success); color: white; }
        .unsold { background: var(--danger); color: white; }
        .undo { background: var(--warning); color: #222; width: 100%; margin-top: 5px; }
        .reset { background: var(--info); color: white; width: 100%; margin-top: 5px; }
        .teams-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; margin-top: 40px; }
        .team-box { background: white; padding: 15px; border-radius: 15px; border-left: 6px solid var(--primary); box-shadow: 0 5px 15px rgba(0,0,0,0.05); text-align: left; }
        .purse-info { color: var(--danger); font-weight: bold; font-size: 18px; display: block; margin-top: 5px; }
        .limit-tag { background: #e8f5e9; color: var(--success); font-size: 11px; padding: 2px 6px; border-radius: 4px; font-weight: bold; }
        .initial-val { font-size: 10px; color: #888; display: block; }
    </style>
</head>
<body>

    <h1 style="text-align:center; color:var(--primary);">🏏 AUCTION CONTROL CENTER</h1>
    
    <div class="auction-card">
        <img id="playerPhoto" src="https://via.placeholder.com/180" alt="Player">
        <h2 id="playerName">Loading Players...</h2>
        <p id="playerType">-</p>
        <div id="liveLimit" style="color:var(--success); font-weight:bold; margin-bottom:10px; min-height: 20px;"></div>
        
        <div class="controls">
            <input type="number" id="price" placeholder="Enter Price (₹)">
            <select id="teamSelect" onchange="updateLimitUI()">
                <option value="">-- Select Team --</option>
            </select>
            <div class="btn-row">
                <button class="sold" onclick="process('SOLD')">SOLD</button>
                <button class="unsold" onclick="process('UNSOLD')">UNSOLD</button>
            </div>
            <button class="undo" onclick="process('UNDO')">↩️ Undo Last</button>
            <button class="reset" onclick="process('RESET_UNSOLD')">🔄 Reset Unsold</button>
        </div>
    </div>

    <div id="teamsDisplay" class="teams-grid"></div>

<script>
    // --- API CONFIG ---
    const mainAPI = "https://script.google.com/macros/s/AKfycbx4OBlVp-XgSXJdt4S04PAJII4bJhxYnCU6_9O3QFdr75_0XnYmw4JG3XDQbE0S32jQ1w/exec";

    let players = [];
    let teams = [];
    let currentLimit = 0;

    // 1. DATA LOAD (Players, Teams & Status)
    async function init() {
        try {
            const t = new Date().getTime();
            const [pRes, tRes] = await Promise.all([
                fetch(mainAPI + "?action=players&t=" + t).then(r => r.json()),
                fetch(mainAPI + "?action=teams&t=" + t).then(r => r.json())
            ]);

            // Filter: Sirf wo players jo SOLD nahi hue hain
            players = pRes.filter(p => !p.team || p.team === "" || p.status === "AVAILABLE");

            // Teams Mapping with Balance & Spent Logic
            teams = tRes.map(t => {
                const sheetPurse = parseFloat(t.purse) || 50000; 
                // Sold sheet ka data pRes ke andar team/status field me hai
                const squad = pRes.filter(p => p.team && p.team.trim() === t.name.trim() && p.status === "SOLD");
                const spent = squad.reduce((sum, p) => sum + (parseFloat(p.price) || 0), 0);
                const balance = sheetPurse - spent;
                
                // Max Bid Rule: 13 squad limit (Saving 1000 for each empty slot)
                let maxBid = (squad.length < 13) ? (balance - ((13 - squad.length - 1) * 1000)) : balance;
                
                return { 
                    name: t.name, 
                    sheetPurse: sheetPurse, 
                    balance: balance, 
                    squadCount: squad.length, 
                    maxBid: maxBid < 0 ? 0 : maxBid 
                };
            });

            renderUI();
        } catch (e) {
            console.error("Fetch Error:", e);
            document.getElementById("playerName").innerText = "Sync Error! Check API.";
        }
    }

    // 2. UI RENDER
    function renderUI() {
        const select = document.getElementById("teamSelect");
        const display = document.getElementById("teamsDisplay");
        select.innerHTML = '<option value="">-- Select Team --</option>';
        display.innerHTML = "";

        // Render Teams
        teams.forEach(t => {
            select.add(new Option(t.name, t.name));
            display.innerHTML += `
                <div class="team-box">
                    <b style="font-size:16px;">${t.name}</b>
                    <span class="limit-tag">Max Bid: ₹${t.maxBid.toLocaleString()}</span>
                    <span class="purse-info">Balance: ₹${t.balance.toLocaleString()}</span>
                    <span class="initial-val">Initial Pars: ₹${t.sheetPurse.toLocaleString()} | Squad: ${t.squadCount}/13</span>
                </div>`;
        });

        // Render Current Player
        if (players.length > 0) {
            const p = players[0];
            document.getElementById("playerName").innerText = p.name.toUpperCase();
            document.getElementById("playerType").innerText = p.type + " | " + (p.address || "No Address");
            document.getElementById("playerPhoto").src = getPhoto(p.photo);
        } else {
            document.getElementById("playerName").innerText = "AUCTION FINISHED";
            document.getElementById("playerPhoto").src = "https://via.placeholder.com/180?text=FINISHED";
        }
    }

    // 3. UPDATE LIMIT ON SELECT
    function updateLimitUI() {
        const val = document.getElementById("teamSelect").value;
        const text = document.getElementById("liveLimit");
        if (!val) { text.innerText = ""; currentLimit = 0; return; }
        
        const t = teams.find(team => team.name === val);
        currentLimit = t.maxBid;
        text.innerText = "Team Bidding Limit: ₹" + t.maxBid.toLocaleString();
    }

    // Photo Link Fixer
    function getPhoto(link) {
        if (!link) return "https://via.placeholder.com/180";
        let id = link.includes("id=") ? link.split("id=")[1].split("&")[0] : link.includes("/d/") ? link.split("/d/")[1].split("/")[0] : "";
        return id ? "https://lh3.googleusercontent.com/d/" + id : link;
    }

    // 4. PROCESS ACTION (SOLD/UNSOLD/UNDO/RESET)
    async function process(type) {
        const team = document.getElementById("teamSelect").value;
        const price = document.getElementById("price").value;
        const player = players[0]?.name;

        if (type === 'SOLD') {
            if (!team || !price) { alert("Pehle Team aur Price bharein!"); return; }
            if (parseFloat(price) > currentLimit) { alert("Budget Allowance Error: Team ki limit cross ho rahi hai!"); return; }
        }

        const payload = { 
            action: type, 
            player: player, 
            team: type === 'SOLD' ? team : (type === 'UNSOLD' ? 'NONE' : ''), 
            price: price || 0, 
            status: type 
        };

        // UI Lock
        document.querySelectorAll("button").forEach(b => b.disabled = true);
        
        try {
            const response = await fetch(mainAPI, { 
                method: "POST", 
                body: JSON.stringify(payload) 
            });
            const resText = await response.text();
            
            if (resText.includes("Successful") || resText.includes("Done")) {
                location.reload(); 
            } else {
                alert("Server Response: " + resText);
                document.querySelectorAll("button").forEach(b => b.disabled = false);
            }
        } catch (e) { 
            alert("Network Error! Check your connection."); 
            document.querySelectorAll("button").forEach(b => b.disabled = false);
        }
    }

    init();
</script>
</body>
</html>